{
    "$schema": "https://turborepo.com/schema.json",
    "tasks": {
        "build": {
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["dist/**", "storybook-static/**", ".next/**", "out/**"],
            "dependsOn": ["^build"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "clean": {
            "cache": false
        },
        "storybook": {
            "cache": false,
            "persistent": true,
            "dependsOn": ["^build"]
        },
        "build-storybook": {
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": ["storybook-static/**"],
            "dependsOn": ["^build"]
        },
        "preview-storybook": {
            "dependsOn": ["^build"],
            "cache": false
        },
        "generate-manifest": {
            "inputs": [
                "../../packages/blend/lib/components/**/types.ts",
                "../../packages/blend/lib/components/**/types.tsx",
                "../../packages/blend/lib/tokens/*.tokens.ts",
                "meta-overrides/**/*.json",
                "generateManifest.js"
            ],
            "outputs": ["manifest.json"],
            "cache": true
        }
    }
}
